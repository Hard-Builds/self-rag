ENV=local
LOG_LEVEL=DEBUG

# Database (Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=self_rag
DB_USER=postgres
DB_PASSWORD=postgres
DB_ECHO=false

# CORS (comma-separated origins)
CORS_ALLOWED_URL=http://localhost:3000,http://localhost:8000

#Gemini LLM config
GEMINI_API_KEY=""
GEMINI_MODEL=""
GEMINI_EMBEDDING_MODEL=""

# Context evaluation thresholds (chunk relevance scores, 0.0–1.0)
CONTEXT_EVAL_HIGHER_THR=0.7
CONTEXT_EVAL_LOWER_THR=0.3

# Redis
REDIS_URL=redis://localhost:6379/0

# Internal service auth
INTERNAL_TOKEN=changeme